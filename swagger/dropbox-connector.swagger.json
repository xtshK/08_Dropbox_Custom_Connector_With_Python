    "/triggers/file-changes": {
      "get": {
        "operationId": "OnFileChanged",
        "summary": "Monitor File Changes (Trigger)",
        "description": "Polling trigger that monitors a Dropbox folder (including Team Folders) for file changes.",
        "tags": [
          "Triggers"
        ],
        "parameters": [
          {
            "name": "path",
            "in": "query",
            "required": true,
            "type": "string",
            "description": "Folder path to monitor, e.g. /Team Folder",
            "x-ms-summary": "Path",
            "x-ms-dynamic-values": {
              "operationId": "GetFolderOptions",
              "value-path": "value",
              "value-title": "display_name"
            }
          },
          {
            "name": "cursor",
            "in": "query",
            "required": false,
            "type": "string",
            "description": "Cursor from previous poll (internal)",
            "x-ms-visibility": "internal",
            "x-ms-summary": "Cursor"
          },
          {
            "name": "recursive",
            "in": "query",
            "required": false,
            "type": "boolean",
            "description": "Monitor subfolders",
            "default": true,
            "x-ms-summary": "Recursive"
          }
        ],
        "responses": {
          "200": {
            "description": "Changes detected",
            "schema": {}
          },
          "202": {
            "description": "No changes, retry later"
          },
          "422": {
            "description": "Validation Error",
            "schema": {
              "$ref": "#/definitions/HTTPValidationError"
            }
          }
        },
        "x-ms-trigger": "batch",
        "x-ms-trigger-hint": "Monitors a Dropbox folder for file changes"
      }
    },
