        "description": "Returns folder list for dynamic dropdown in Power Automate.",
        "tags": [
          "Folders"
        ],
        "parameters": [
          {
            "name": "parent_path",
            "in": "query",
            "required": false,
            "type": "string",
            "description": "Parent folder path (empty = root)",
