{
  "swagger": "2.0",
  "info": {
    "title": "Dropbox Business Connector",
    "description": "Custom Connector for Power Automate — Dropbox Business with Team Folder support",
    "version": "1.0.0"
  },
  "host": "localhost:8000",
  "basePath": "/",
  "schemes": [
